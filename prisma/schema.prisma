generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String                   @id @default(uuid())
  name        String
  email       String                   @unique
  password    String
  role        UserRole                 @default(USER)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  submissions CompensationSubmission[]
}

model Company {
  id             Int                      @id @default(autoincrement())
  name           String                   @unique
  normalizedName String                   @unique
  createdAt      DateTime                 @default(now())
  submissions    CompensationSubmission[]
}

model Role {
  id          Int                      @id @default(autoincrement())
  name        String                   @unique
  submissions CompensationSubmission[]
}

model Level {
  id          Int                      @id @default(autoincrement())
  name        String                   @unique
  submissions CompensationSubmission[]
}

model Location {
  id          Int                      @id @default(autoincrement())
  city        String
  country     String
  submissions CompensationSubmission[]

  @@unique([city, country])
}

model CompensationSubmission {
  id                String            @id @default(uuid())
  userId            String
  companyId         Int
  roleId            Int
  levelId           Int
  locationId        Int
  baseSalary        Decimal           @db.Decimal(12, 2)
  bonus             Decimal           @default(0) @db.Decimal(12, 2)
  stock             Decimal           @default(0) @db.Decimal(12, 2)
  totalCompensation Decimal           @db.Decimal(12, 2)
  confidenceScore   Int
  verified          Boolean           @default(false)
  status            SubmissionStatus  @default(PENDING_REVIEW)
  source            SubmissionSource  @default(USER)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  company           Company           @relation(fields: [companyId], references: [id])
  level             Level             @relation(fields: [levelId], references: [id])
  location          Location          @relation(fields: [locationId], references: [id])
  role              Role              @relation(fields: [roleId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
  audits            SubmissionAudit[]

  @@index([companyId])
  @@index([roleId])
  @@index([levelId])
  @@index([locationId])
  @@index([status])
  @@index([createdAt])
  @@index([companyId, levelId, locationId])
}

model SubmissionAudit {
  id             String                 @id @default(uuid())
  submissionId   String
  actionBy       String?
  previousStatus SubmissionStatus
  newStatus      SubmissionStatus
  reason         String?
  createdAt      DateTime               @default(now())
  submission     CompensationSubmission @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
}

enum UserRole {
  USER
  ADMIN
}

enum SubmissionStatus {
  APPROVED
  PENDING_REVIEW
  FLAGGED
  REJECTED
}

enum SubmissionSource {
  SYSTEM
  USER
}
